# CrabScholar Configuration
# Copy this to .env and fill in your values

# LLM API Keys (at least one required)
# For Google Gemini (recommended):
CRAB_GEMINI_API_KEY=

# For OpenAI:
# CRAB_OPENAI_API_KEY=sk-...

# For Anthropic:
# CRAB_ANTHROPIC_API_KEY=sk-ant-...

# Generic API key (fallback, exported as OPENAI_API_KEY):
# CRAB_API_KEY=sk-...

# Custom API Base URL (optional, for local models / vLLM / etc.)
# CRAB_BASE_URL=http://localhost:8000/v1

# Semantic Scholar API Key (optional, higher rate limits)
# CRAB_SCHOLAR_API_KEY=

# Default model (uses LiteLLM format: provider/model-name)
# Examples:
#   gemini/gemini-2.5-flash     (Google Gemini)
#   openai/gpt-4o-mini          (OpenAI)
#   anthropic/claude-3-haiku    (Anthropic)
# CRAB_DEFAULT_MODEL=gemini/gemini-2.5-flash

# Fallback models (JSON array format)
# CRAB_FALLBACK_MODELS=["gemini/gemini-2.0-flash","openai/gpt-4o-mini"]
